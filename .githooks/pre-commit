#!/usr/bin/env sh
set -eu

if ! command -v bun >/dev/null 2>&1; then
	printf "[pre-commit] Bun not found in PATH; skipping local checks (CI will enforce).\n"
	exit 0
fi

printf "[pre-commit] Running Biome checks...\n"
bunx @biomejs/biome check . || { printf "Biome checks failed.\n"; exit 1; }

printf "[pre-commit] Running Bun tests...\n"
bun test || { printf "Bun tests failed.\n"; exit 1; }

printf "[pre-commit] All checks passed.\n"
